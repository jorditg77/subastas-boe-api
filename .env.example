# Puerto local de la aplicación
PORT=3000

# Modo: development | production
NODE_ENV=production

# Clave secreta para validar requests de RapidAPI (opcional, RapidAPI valida por host + key)
RAPIDAPI_PROXY_SECRET=tu_secreto_aqui

# Cloudflare Tunnel no requiere configuración aquí; se ejecuta externamente con cloudflared
# Comando típico: cloudflared tunnel --no-autoupdate run --token <TOKEN>

# Límites de caché (MB)
CACHE_MAX_MEMORY_MB=1500
CACHE_AUCTION_TTL_SECONDS=14400
CACHE_SEARCH_TTL_SECONDS=7200
CACHE_PROVINCES_TTL_SECONDS=86400

# Límites de scraping al BOE
BOE_MAX_CONCURRENT_REQUESTS=3
BOE_REQUEST_DELAY_MS=1000
BOE_RETRY_ATTEMPTS=3
BOE_RETRY_BACKOFF_MS=2000

# Logging
LOG_LEVEL=info
